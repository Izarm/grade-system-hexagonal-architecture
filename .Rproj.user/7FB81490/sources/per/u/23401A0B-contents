# Instalar y cargar los paquetes necesarios
install.packages("arules")
install.packages("arulesViz")
install.packages("visNetwork")
install.packages("tidyverse")

library(arules)
library(arulesViz)
library(visNetwork)
library(tidyverse)

Cesta <- read.csv("C:/Users/Fabian Realpe/Desktop/Dataset/bank_traducido_cualitativ.csv", sep=",", header=TRUE, fileEncoding = "utf-8")
", sep=",", header=TRUE, fileEncoding = "utf-8")

# Verificar las primeras filas para asegurarse de que se cargaron correctamente

head(Cesta) 

# Convertir los datos a un objeto de transacción
transacciones <- read.transactions(file = "C:/Users/Fabian Realpe/Desktop/Dataset/bank_traducido_cualitativ.csv",
                                   format = "basket", 
                                   sep = ";", 
                                   header = TRUE)


# Verificar los nombres de los items y las primeras transacciones
colnames(transacciones)
inspect(head(transacciones))

# Identificar itemsets frecuentes
itemsets_frecuentes <- apriori(data = transacciones,
                               parameter = list(support = 0.10,  # soporte mínimo
                                                minlen = 2,  # número mínimo de items por itemsets
                                                maxlen = 12,  # número máximo de items por itemsets
                                                target = "frequent itemset"))

# Ver los itemsets frecuentes
inspect(itemsets_frecuentes)

# Generar reglas de asociación
reglas <- apriori(data = transacciones,
                  parameter = list(supp = 0.10,  # soporte mínimo
                                   minlen = 2,  # número mínimo de items por itemsets
                                   maxlen = 20,  # número máximo de items por itemsets
                                   conf = 0.40,  # confianza mínima
                                   target = "rules"))

# Ver las reglas generadas
inspect(reglas)

# Visualización de las reglas utilizando el método 'graph'
plot(reglas, method="graph", engine="htmlwidget", shading="confidence")

# Filtrar reglas con alta confianza y soporte
reglas_filtradas <- subset(reglas, confidence > 0.7 & support > 0.01)

# Graficar las reglas filtradas
plot(reglas_filtradas, method="graph", engine="interactive", shading="lift", max=20)

# Graficar usando 'igraph' para visualizar las relaciones entre los items
plot(reglas_filtradas, method="graph", engine="igraph", shading="confidence", control = list(type = "items"))

# Añadir los indicadores 'leverage' y 'conviction' a las reglas
quality(reglas) <- cbind(quality(reglas),
                         leverage = interestMeasure(reglas, measure = "leverage", transactions = transacciones),
                         conviction = interestMeasure(reglas, measure = "conviction", transactions = transacciones))

# Inspeccionar las reglas por confianza
inspect(reglas, by = "confidence")

# Graficar las reglas con los indicadores de calidad
plot(reglas, method="graph", engine="htmlwidget", shading="confidence")

# Verificar si hay reglas redundantes
reduntantes <- is.redundant(reglas)
reduntantes

# Identificar las reglas redundantes
which(is.redundant(reglas))

# Representación en grafos usando visNetwork
ig <- plot(reglas_filtradas, method = "graph", engine = "igraph", control = list(type = "items"))
visNetwork::visIgraph(ig)


